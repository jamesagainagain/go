# CORE
# Preferred for Supabase deployments:
SUPABASE_DB_URL=
# Backward-compatible local override:
DATABASE_URL=postgresql+asyncpg://firstmove:password@localhost:5432/firstmove
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production

# Supabase REST seeding support (used by scripts.seed_supabase_demo_places)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# VOICE (Profile setup - ElevenLabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# MAPS / GEO
MAPBOX_ACCESS_TOKEN=pk.ey...
MAPBOX_STYLE=mapbox://styles/mapbox/light-v11

# NOTIFICATIONS
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=team@firstmove.dev

# EVENT SOURCES (optional, for ingestion)
ENABLE_PLACES_CATALOG_INGESTION=true
MEETUP_API_KEY=
EVENTBRITE_API_KEY=
TIMEOUT_API_KEY=
OPENCLAW_ENABLED=false
OPENCLAW_ENDPOINT=
OPENCLAW_API_TOKEN=
OPENCLAW_TIMEOUT_SECONDS=4.0

# CALENDAR (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# FRONTEND (Next.js - add to .env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.ey...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# APP CONFIG
DEFAULT_CITY=london
DEFAULT_RADIUS_KM=5
ACTIVATION_CHECK_INTERVAL_MINUTES=15
MAX_OPPORTUNITIES_PER_ACTIVATION=3
LOG_LEVEL=INFO
